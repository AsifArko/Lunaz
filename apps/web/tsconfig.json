{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "types": ["../../types"],
      "types/*": ["../../types/*"],
      "interfaces": ["../../interfaces"],
      "interfaces/*": ["../../interfaces/*"],
      "constants": ["../../constants"],
      "constants/*": ["../../constants/*"],
      "manage-settings/*": ["src/features/manage/settings/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }],
  "types": ["vite/client"]
}
