# ============================================================================
# Lunaz — Environment Variables
# ============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real secrets to version control!
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/lunaz
# For Docker: mongodb://mongodb:27017/lunaz

# JWT authentication
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# S3 / MinIO (Object Storage)
# ─────────────────────────────────────────────────────────────────────────────
S3_BUCKET=lunaz-products
S3_REGION=us-east-1

# For local development with MinIO:
S3_ENDPOINT=http://localhost:9000
# For Docker: http://minio:9000

# MinIO / AWS credentials
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MinIO root credentials (Docker only)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─────────────────────────────────────────────────────────────────────────────
# CORS / Frontend URLs
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MANAGE_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (Payment processing - optional)
# ─────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────────────────────
# OAuth (Social Login)
# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth - Get credentials from: https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth - Get credentials from: https://developers.facebook.com/apps
# VITE_FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Build-time variables)
# ─────────────────────────────────────────────────────────────────────────────
# These are embedded at build time in Vite apps
VITE_API_URL=http://localhost:4000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# Production overrides (examples)
# ─────────────────────────────────────────────────────────────────────────────
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lunaz
# JWT_SECRET=<generate-secure-random-string>
# S3_ENDPOINT=  # Leave empty to use real AWS S3
# AWS_ACCESS_KEY_ID=<aws-access-key>
# AWS_SECRET_ACCESS_KEY=<aws-secret-key>
# FRONTEND_WEB_URL=https://lunaz.example.com
# FRONTEND_MANAGE_URL=https://admin.lunaz.example.com
# VITE_API_URL=https://api.lunaz.example.com/api/v1
