# ============================================================================
# Lunaz — Environment Variables
# ============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real secrets to version control!
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/lunaz
# For Docker: mongodb://mongodb:27017/lunaz

# JWT authentication (access token short-lived; refresh token long-lived)
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 (Object Storage for product and category images)
# ─────────────────────────────────────────────────────────────────────────────
S3_BUCKET=lunaz
S3_REGION=us-east-1

# AWS credentials (required for image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# CORS / Frontend URLs
# ─────────────────────────────────────────────────────────────────────────────
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MANAGE_URL=http://localhost:3001


API_URL=http://localhost:4000

SSLCOMMERZ_SANDBOX=true
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Build-time variables)
# ─────────────────────────────────────────────────────────────────────────────
# These are embedded at build time in Vite apps
VITE_API_URL=http://localhost:4000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# EC2 / Production (docker-compose.ec2.yml)
# ─────────────────────────────────────────────────────────────────────────────
# Set these on EC2 server. TAG and REGISTRY_IMAGE are set by deploy script.
# TAG=abc1234
# REGISTRY_IMAGE=ghcr.io/owner/repo
