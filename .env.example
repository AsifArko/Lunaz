# ============================================================================
# Lunaz — Environment Variables
# ============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real secrets to version control!
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/lunaz
# For Docker: mongodb://mongodb:27017/lunaz

# JWT authentication (access token short-lived; refresh token long-lived)
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 (Object Storage for product and category images)
# ─────────────────────────────────────────────────────────────────────────────
S3_BUCKET=lunaz
S3_REGION=us-east-1

# AWS credentials (required for image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# CORS / Frontend URLs (backend uses these for CORS and callbacks)
# ─────────────────────────────────────────────────────────────────────────────
# Local: use localhost. Production: use your public URL (http or https)
FRONTEND_WEB_URL=http://localhost:3000
FRONTEND_MANAGE_URL=http://localhost:3001

# Backend's own URL (for SSLCommerz callbacks, etc.)
API_URL=http://localhost:4000

SSLCOMMERZ_SANDBOX=true
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=

# Google OAuth (required for "Sign in with Google")
# Get from https://console.cloud.google.com/apis/credentials
# Add https://YOUR_DOMAIN/auth/google/callback to Authorized redirect URIs
# Add https://YOUR_DOMAIN to Authorized JavaScript origins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Build-time variables — set in GitHub Secrets for CI)
# ─────────────────────────────────────────────────────────────────────────────
# Baked into web/manage Docker images at build time. Must be reachable from user's browser.
# Production: http://YOUR_EC2_IP:4000/api/v1 or https://api.your-domain.com/api/v1
VITE_API_URL=http://localhost:4000/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# EC2 / Production (docker-compose.ec2.yml) — HTTPS via Nginx
# ─────────────────────────────────────────────────────────────────────────────
# Nginx terminates SSL with a self-signed cert. Use https:// with your public IP.
# IMPORTANT: CORS origins must match exactly what the browser sends:
#   - Web:    FRONTEND_WEB_URL=https://18.191.194.81
#   - Manage: FRONTEND_MANAGE_URL=https://18.191.194.81:3001
#   - API:    API_URL=https://18.191.194.81
# In GitHub Secrets, set VITE_API_URL=https://18.191.194.81/api/v1 (then rebuild)
# Browsers will show a certificate warning (expected for self-signed).
#
# EC2 Security Group: allow inbound 80, 443, 3001 (22 for SSH).
#
# TAG=abc1234
# REGISTRY_IMAGE=ghcr.io/owner/repo
